NODE_ENV=production
PORT=8000

MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/isaves?retryWrites=true&w=majority

JWT_SECRET=replace_with_a_long_random_secret_64_characters
ENCRYPTION_SECRET=replace_with_a_long_random_secret_64_characters

GOOGLE_CLIENT_ID=your-production-google-client-id.apps.googleusercontent.com

FRONTEND_ORIGIN=https://your-frontend-domain.com

PASSWORD_RESET_TTL_MINUTES=10